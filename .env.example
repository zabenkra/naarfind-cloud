# =============================================================================
# NaarFind — copy to .env for LOCAL development (docker compose)
# Never commit .env to git.
# =============================================================================

ENVIRONMENT=development

# --- Database (required everywhere) ---
# docker-compose.yml sets DATABASE_URL for the backend service (local Postgres @ db).
# Run backend outside compose: uncomment the line below.
# DATABASE_URL=postgresql://naarfind:naarfind123@db:5432/naarfind
# Railway / Supabase: set DATABASE_URL only in the Railway dashboard (not in a baked .env).
DATABASE_URL=

# --- JWT (production: openssl rand -hex 32) ---
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS (production: set to your Vercel URL) ---
FRONTEND_URL=http://localhost:5173
# CORS_ORIGINS=https://extra-origin.example.com

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
ALLOWED_MEDIA_URL_PREFIXES=

# --- Edge agent (Raspberry Pi) ---
DEVICE_UID=pi-001
DEVICE_API_KEY=SUPER_SECRET_KEY_123
CLOUD_API_URL=http://localhost:8000

# --- Local only (Render sets PORT automatically in production) ---
PORT=8000

# =============================================================================
# PRODUCTION (Render Web Service) — set these in Render dashboard, NOT in .env file
# =============================================================================
# ENVIRONMENT=production
# DATABASE_URL=<Render PostgreSQL Internal URL>
# JWT_SECRET_KEY=<openssl rand -hex 32>
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
# FRONTEND_URL=https://your-app.vercel.app
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=
# PORT is injected by Render — do not set manually
