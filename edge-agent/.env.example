DEVICE_API_KEY=SUPER_SECRET_KEY_123
CLOUD_API_URL=http://localhost:8000

RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=2

# Cloudflare R2 (or set these in the project root .env)
R2_ACCOUNT_ID=
