# Local overrides for the Pi. Root project .env is loaded first.
DEVICE_UID=pi-001
DEVICE_API_KEY=your-device-api-key
CLOUD_API_URL=https://your-api.up.railway.app
AGENT_VERSION=1.0.0

HEARTBEAT_INTERVAL_SECONDS=30
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=2

# --- YOLO fire/smoke model ---
MODEL_PATH=./models/fire_smoke_yolov8n_ncnn_model
MODEL_FALLBACK_PATH=./models/fire_smoke_yolov8n.pt
MODEL_IMG_SIZE=416
FIRE_THRESHOLD=0.55
SMOKE_THRESHOLD=0.65
DETECTION_COOLDOWN=30

# --- Camera ---
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=20
PROCESS_EVERY_N_FRAMES=3
ENABLE_DEBUG_WINDOW=false

# --- Snapshots ---
SAVE_SNAPSHOTS=true
UPLOAD_SNAPSHOTS=true
SNAPSHOT_DIR=./snapshots

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
