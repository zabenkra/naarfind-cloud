# Local overrides for the Pi. Root project .env is loaded first.
DEVICE_UID=pi-001
DEVICE_API_KEY=your-device-api-key
CLOUD_API_URL=http://localhost:8000
AGENT_VERSION=1.0.0

HEARTBEAT_INTERVAL_SECONDS=30
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=2

# Cloudflare R2 (or set in project root .env)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
