# =============================================================================
# Frontend environment (Vite — prefix VITE_)
# Copy to .env.local for local dev, or set in Vercel dashboard for production.
# =============================================================================

# --- Local development ---
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/events

# --- Production (Vercel / Railway) ---
# VITE_API_URL=https://naarfind-cloud-production.up.railway.app
# VITE_WS_URL must include /ws/events (or base URL — app will append path)
# VITE_WS_URL=wss://naarfind-cloud-production.up.railway.app/ws/events
